# === Database ===
DATABASE_URL=postgresql+asyncpg://modai:modai_secret@db:5432/modai
DATABASE_URL_SYNC=postgresql://modai:modai_secret@db:5432/modai
POSTGRES_USER=modai
POSTGRES_PASSWORD=modai_secret
POSTGRES_DB=modai

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === JWT ===
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === OpenAI ===
OPENAI_API_KEY=sk-your-openai-api-key-here

# === Google Gemini ===
GOOGLE_API_KEY=your-google-ai-studio-key-here

# === App ===
APP_ENV=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# === LangSmith (Observability) ===
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=modai-chatbot

# === RAG Settings ===
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.30

# === Chat Settings ===
CHAT_MAX_HISTORY_MESSAGES=10
